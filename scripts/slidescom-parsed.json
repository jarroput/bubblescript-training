      },
      {
        "type": "code",
        "top": 118,
        "left": 198.5,
        "lang": "text",
        "code": "@about intent(\n         match: [\"about _ (restaurant | sienna)\"]\n       )\n\ndialog trigger: @about do\n  say \"We serve traditional Italian pizza's.\"\nend\n"
