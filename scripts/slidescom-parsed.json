        "type": "text",
        "top": 0,
        "left": 340,
        "markdown": "Special dialog triggers"
      },
      {
        "type": "code",
        "top": 124,
        "left": 175,
        "lang": "text",
        "code": "# same as main\ndialog __main__ do\n  say \"Hi!\"\nend\n\n# fires when there are no more dialogs left to execute\ndialog __root__ do\n  say \"What can I do for you?\"\nend\n\n# fires when a user message isn't triggering anything else\ndialog __unknown__ do\n  say \"I don't understand\"  \nend\n\n# triggers when a close statement is fired\ndialog __closed__ do\n  say \"Goodbye!\"\nend\n",
        "lineNumbers": "2|7|12|17"
      }
    ]
  },
