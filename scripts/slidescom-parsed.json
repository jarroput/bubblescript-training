        "markdown": "Intent definition using BML"
      },
      {
        "type": "code",
        "top": 146.5,
        "left": 89,
        "lang": "text",
        "code": "dialog trigger: intent(match: [\"about _ (restaurant | sienna)\"]) do\n  say \"We serve traditional Italian pizza's.\"\nend"
