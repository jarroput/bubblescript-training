  {
    "blocks": [
      {
        "type": "text",
        "top": 0,
        "left": 340,
        "markdown": "__returning__"
      },
      {
        "type": "code",
        "top": 144,
        "left": 80,
        "lang": "text",
        "code": "dialog order do\n  say \"Let's take your order…\"\n  \n  ask \"What pizza would you like to order?\",\n    expecting: [\"Margherita\", \"Pepperoni\", \"Hawaii\"]\n  \n  say \"We'll start preparing your #{answer}!\"\n  \n  dialog trigger: \"caprese\", do: say \"The Caprese Pizza is out of order\"\n  dialog trigger: \"pasta\"  , do: say \"We don't serve pasta's, only pizza's\"\n  dialog __unknown__       , do: say \"Sorry, that is not on our menu…\"\n  \n  dialog __returning__ do\n    say \"Let's continue with your order…\"\n  end\nend  ",
        "lineNumbers": "13-15"
      }
    ]
  },
